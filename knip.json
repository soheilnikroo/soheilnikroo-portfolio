{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["app/**/*.{ts,tsx}", "scripts/**/*.{mjs,mts}"],
  "project": ["**/*.{ts,tsx,mjs,mts}"],
  "ignore": ["tooling/**"],
  "ignoreFiles": ["lib/world/three-patched.ts"],
  "ignoreBinaries": ["ffmpeg"],
  "ignoreDependencies": [
    "@tailwindcss/typography",
    "tailwindcss",
    "tw-animate-css",
    "shadcn",
    "@commitlint/cli"
  ],
  "rules": {
    "exports": "off",
    "types": "off",
    "enumMembers": "off"
  }
}
